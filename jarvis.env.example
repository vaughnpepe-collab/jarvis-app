# ===========================================================================
#  J.A.R.V.I.S. — API keys
# ---------------------------------------------------------------------------
#  HOW TO USE:
#    1. Rename this file to exactly:  jarvis.env   (remove ".example")
#    2. Put your key after the = sign on the matching line below.
#    3. Save, then start JARVIS. The header should show your provider, not DEMO.
#
#  Notes:
#    - One KEY=value per line. No quotes needed. Lines starting with # are off.
#    - Keep this file private — it contains secrets. Don't share or commit it.
#    - A real shell environment variable, if set, always wins over this file.
# ===========================================================================

# --- NVIDIA NIM (DeepSeek v4, MiniMax M3, Llama, etc.) ---------------------
# Get a key at https://build.nvidia.com . This one key powers BOTH the
# "NVIDIA NIM" brain (DeepSeek by default) and the "MiniMax M3" brain.
NVIDIA_API_KEY=

# Optional: change which model each NVIDIA-based brain uses.
#NVIDIA_MODEL=deepseek-ai/deepseek-v4-pro
#MINIMAX_MODEL=minimaxai/minimax-m3

# --- Anthropic (Claude API) -----------------------------------------------
#ANTHROPIC_API_KEY=

# --- OpenAI (and OpenAI-compatible servers) -------------------------------
#OPENAI_API_KEY=

# --- Others (uncomment and fill any you have) -----------------------------
#DEEPSEEK_API_KEY=
#GEMINI_API_KEY=
#GROQ_API_KEY=
#MISTRAL_API_KEY=
#XAI_API_KEY=

# --- Pick a default brain (optional) --------------------------------------
# Otherwise JARVIS auto-selects the first configured one.
#JARVIS_BRAIN=nvidia
